\newcommand{\lexbox}[5]{\node[#2, text width=#1, anchor=north] (#3) #4 {#5};}

\newcommand{\litbox}[4][3cm]{\lexbox{#1}{lit_definition}{#2}{#3}{#4}}
\newcommand{\assbox}[4][3cm]{\lexbox{#1}{ass_definition}{#2}{#3}{#4}}
\newcommand{\metbox}[4][3cm]{\lexbox{#1}{met_definition}{#2}{#3}{#4}}

% typesetting:
\newcommand{\defn}[1]{{\textbf{#1}}}
\newcommand{\metaphor}[1]{\textsc{#1}}
\newcommand{\word}[1]{\textit{#1}}
\newcommand{\concept}[1]{\textsc{#1}}
\newcommand{\letter}[1]{\texttt{#1}}
\newcommand{\sense}[2]{\word{#1}\textsubscript{${#2}$}} %%% FCB
\newcommand{\synonym}[1]{\textit{#1}}

